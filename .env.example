# Configuración de Red/API
BACKEND_PORT=8000
FRONTEND_PORT=3000
BASE_URL=http://localhost

# Variables para el Frontend (Vite)
VITE_BACKEND_PORT=8000
VITE_FRONTEND_PORT=3000
VITE_BASE_URL=http://localhost

# Configuración de Base de Datos (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=usuario_del_crm
DB_PASSWORD=una_contraseña_segura
MASTER_DB_NAME=master_db
DB_NAME=master_db

# Seguridad
# Generar una llave secreta fuerte para producción (ej: openssl rand -hex 32)
SECRET_KEY=mi_llave_secreta_super_segura
# Tiempo de expiración del token JWT en minutos
TOKEN_EXP_MIN=60

# Email / SMTP (para recuperación de contraseña y notificaciones)
# Gmail: habilitar "Contraseñas de aplicación" en https://myaccount.google.com/apppasswords
# Outlook/Hotmail: SMTP_HOST=smtp.office365.com  SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_contraseña_de_aplicacion
